# Nexus
NEXUS_URL=https://nexus.example.com
NEXUS_HOST=nexus.example.com
NEXUS_USER=
NEXUS_PASSWORD=

# Cooling Proxy Settings
COOLING_DAYS=7
BYPASS_TOKEN=

# LDAP / Active Directory
LDAP_URI=ldap://ldap.example.com:389
LDAP_DOMAIN=EXAMPLE
LDAP_REQUIRED_GROUP=admins
LDAP_ADMIN_GROUP=admins
LDAP_USER_GROUP=users
LDAP_BASE_DN=DC=example,DC=com

# Dashboard
AUTH_ENABLED=true
LOCAL_ADMIN_PASSWORD=
VALIDATOR_URL=http://validator:8080

# Container Registry (Helm/K8s)
REGISTRY=registry.example.com/org
INGRESS_HOST=artifacts.example.com

# Quarantine / Webhooks
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# Redis
REDIS_URL=redis://redis:6379

# Internal repo name patterns (customize to match your Nexus repo names)
PYPI_REPO_NAME=pypi-proxy
HOSTED_REPO_PREFIX=hosted-
INTERNAL_PKG_SCOPE=@myorg

# Contact
SUPPORT_CONTACT=your-team@example.com
