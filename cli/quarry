#!/usr/bin/env python3
"""
Quarry CLI — Supply chain security gatekeep.

Packages enter the Quarry. Only the proven ones leave.

Usage:
    quarry status                              Show the hold status
    quarry ledger [--limit N]                  View the record of requests
    quarry release <ecosystem> <package>       Free a package from the hold
    quarry seal <ecosystem> <package>          Permanently lock a package away
    quarry unseal <ecosystem> <package>        Remove seal, return to auto policy
    quarry edicts                              Show standing orders (rules)
    quarry inspect <ecosystem> <package> [ver] Examine a package at the gate
    quarry config show                         Show current config
    quarry config set <key> <value>            Update a setting

Aliases (for the uninitiated):
    allow = release, block = seal, clear = unseal
    log = ledger, rules = edicts, simulate = inspect

Supported ecosystems:
    npm, maven, pypi, nuget, go, cargo, gitlab, artifactory, or any custom registry

Examples:
    quarry status
    quarry release maven org.apache.commons:commons-lang3
    quarry seal npm event-stream
    quarry inspect gitlab my-group/my-package 1.2.3
    quarry ledger --limit 10
    quarry config set hold-days 14
"""
import argparse
import json
import os
import sys

try:
    import requests
except ImportError:
    print("Error: 'requests' package required. Install with: pip install requests")
    sys.exit(1)


# ── Config ────────────────────────────────────────────────────────────────

DEFAULT_URL = "http://localhost:8080"
CONFIG_FILE = os.path.expanduser("~/.quarry.json")


def load_config():
    """Load CLI config from ~/.quarry.json"""
    defaults = {"url": DEFAULT_URL, "token": ""}
    if os.path.exists(CONFIG_FILE):
        try:
            with open(CONFIG_FILE) as f:
                saved = json.load(f)
                defaults.update(saved)
        except (json.JSONDecodeError, IOError):
            pass
    return defaults


def save_config(config):
    """Save CLI config to ~/.quarry.json"""
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)


def get_base_url():
    config = load_config()
    return os.environ.get("QUARRY_URL", config.get("url", DEFAULT_URL))


def get_headers():
    config = load_config()
    token = os.environ.get("QUARRY_TOKEN", config.get("token", ""))
    headers = {"Content-Type": "application/json"}
    if token:
        headers["Authorization"] = f"Basic {token}"
    return headers


# ── Helpers ───────────────────────────────────────────────────────────────

def api_get(path, params=None):
    url = f"{get_base_url()}{path}"
    try:
        r = requests.get(url, headers=get_headers(), params=params, timeout=10)
        r.raise_for_status()
        return r.json()
    except requests.ConnectionError:
        print(f"  Cannot reach the Quarry at {get_base_url()}")
        print(f"  Set QUARRY_URL or run: quarry config set url <your-validator-url>")
        sys.exit(1)
    except requests.HTTPError as e:
        print(f"  Error: {e.response.status_code} — {e.response.text}")
        sys.exit(1)


def api_post(path, data=None):
    url = f"{get_base_url()}{path}"
    try:
        r = requests.post(url, headers=get_headers(), json=data, timeout=10)
        r.raise_for_status()
        return r.json()
    except requests.ConnectionError:
        print(f"  Cannot reach the Quarry at {get_base_url()}")
        sys.exit(1)
    except requests.HTTPError as e:
        print(f"  Error: {e.response.status_code} — {e.response.text}")
        sys.exit(1)


def color(text, code):
    """ANSI color if terminal supports it."""
    if not sys.stdout.isatty():
        return text
    return f"\033[{code}m{text}\033[0m"


def red(text): return color(text, "31")
def green(text): return color(text, "32")
def yellow(text): return color(text, "33")
def blue(text): return color(text, "34")
def purple(text): return color(text, "35")
def dim(text): return color(text, "90")
def bold(text): return color(text, "1")


# ── Commands ──────────────────────────────────────────────────────────────

def cmd_status(args):
    """Show the hold status."""
    health = api_get("/health")
    stats = api_get("/stats")

    hold_days = health.get("cooling_days", health.get("hold_days", "?"))

    print(f"\n  {bold('⛏  Quarry')} — Supply Chain Gatekeep\n")
    print(f"  The Hold:      {green('●')} {health.get('status', 'unknown')}")
    print(f"  Hold Period:   {yellow(str(hold_days))} days")
    print(f"  Cache:         {stats.get('cache', 'unknown')}")

    if "cached_decisions" in stats:
        print(f"\n  Packages tracked: {stats['cached_decisions']}")
    if "rules" in stats:
        rules = stats["rules"]
        sealed = rules.get("block_count", 0)
        released = rules.get("allow_count", 0)
        print(f"  Edicts:         {red(str(sealed))} sealed, {green(str(released))} released")

    print()


def cmd_ledger(args):
    """View the record of requests."""
    data = api_get("/requests", params={"limit": args.limit})

    reqs = data.get("requests", [])
    if not reqs:
        print("  The ledger is empty. No packages have passed through the gate yet.")
        return

    print(f"\n  {'Time':<20} {'Verdict':<12} {'Registry':<10} {'Package':<38} {'Age':<8}")
    print(f"  {'─' * 88}")

    for r in reqs[:args.limit]:
        decision = r.get("decision", "?")
        if "block" in decision:
            dec_str = red("⛔ HELD")
        elif "allow" in decision:
            dec_str = green("✓ RELEASED")
        else:
            dec_str = yellow(decision)

        age = r.get("age_days")
        age_str = f"{age:.1f}d" if age is not None else "—"

        ts = r.get("timestamp", "")[:19].replace("T", " ")
        eco = r.get("ecosystem", "?")

        print(f"  {dim(ts):<20} {dec_str:<12} {eco:<10} {r.get('package', '?'):<38} {age_str:<8}")

    total = data.get("total", len(reqs))
    shown = min(len(reqs), args.limit)
    print(f"\n  {dim(f'Showing {shown} of {total} entries in the ledger')}\n")


def cmd_release(args):
    """Free a package from the hold."""
    data = api_post("/api/packages/override", {
        "package": args.package,
        "ecosystem": args.ecosystem,
        "action": "allow",
    })
    print(f"  {green('✓')} Released {args.ecosystem}/{args.package} from the hold")


def cmd_seal(args):
    """Permanently lock a package away."""
    data = api_post("/api/packages/override", {
        "package": args.package,
        "ecosystem": args.ecosystem,
        "action": "deny",
    })
    print(f"  {red('⛔')} Sealed {args.ecosystem}/{args.package} — permanently held")


def cmd_unseal(args):
    """Remove seal, return to automatic policy."""
    data = api_post("/api/packages/override", {
        "package": args.package,
        "ecosystem": args.ecosystem,
        "action": "clear",
    })
    print(f"  {yellow('↺')} Unsealed {args.ecosystem}/{args.package} — returned to auto policy")


def cmd_edicts(args):
    """Show standing orders (rules)."""
    data = api_get("/rules")

    block_rules = data.get("block", [])
    allow_rules = data.get("allow", [])

    print(f"\n  {bold('📜 Edicts of the Quarry')}\n")

    print(f"  {red('Sealed')} ({len(block_rules)})")
    if block_rules:
        for r in block_rules:
            ver = f"@{r['version']}" if r.get("version") else ""
            eco = r.get("ecosystem", "?")
            print(f"    {red('⛔')} {eco}/{r.get('package', '?')}{ver}")
            print(f"       {dim(r.get('reason', ''))}")
    else:
        print(f"    {dim('No packages sealed')}")

    print(f"\n  {green('Released')} ({len(allow_rules)})")
    if allow_rules:
        for r in allow_rules:
            eco = r.get("ecosystem", "?")
            print(f"    {green('✓')} {eco}/{r.get('package', '?')}")
            print(f"       {dim(r.get('reason', ''))}")
    else:
        print(f"    {dim('No standing releases')}")

    print()


def cmd_inspect(args):
    """Examine a package at the gate."""
    params = {"ecosystem": args.ecosystem, "package": args.package}
    if args.version:
        params["version"] = args.version

    data = api_get("/test/simulate", params=params)

    decision = data.get("decision", "unknown")
    if decision == "block":
        dec_str = red("⛔ HELD")
        verdict = "This package would be held at the gate"
    elif decision == "allow":
        dec_str = green("✓ RELEASED")
        verdict = "This package would pass through"
    else:
        dec_str = yellow(decision)
        verdict = "Unknown verdict"

    ver_str = f"@{args.version}" if args.version else ""
    print(f"\n  {bold('🔍 Inspection Report')}\n")
    print(f"  Package:   {args.ecosystem}/{args.package}{ver_str}")
    print(f"  Verdict:   {dec_str}")
    print(f"  Reason:    {data.get('reason', '—')}")

    if data.get("age_days") is not None:
        print(f"  Age:       {data['age_days']} days")
    if data.get("publish_date"):
        print(f"  Published: {data['publish_date'][:10]}")
    if data.get("cooling_days"):
        print(f"  Threshold: {data['cooling_days']} days")
    if data.get("source"):
        print(f"  Source:    {dim(data['source'])}")

    print(f"\n  {dim(verdict)}\n")


def cmd_config(args):
    """Manage CLI configuration."""
    config = load_config()

    if args.config_action == "show":
        print(f"\n  {bold('⚙  Quarry Config')} ({CONFIG_FILE})\n")
        print(f"  url:    {config.get('url', DEFAULT_URL)}")
        token = config.get("token", "")
        print(f"  token:  {'••••' + token[-4:] if token else dim('not set')}")
        print(f"\n  {dim('Override with QUARRY_URL and QUARRY_TOKEN env vars')}\n")

    elif args.config_action == "set":
        key = args.key
        value = args.value

        # Server-side settings (pushed to the API)
        server_keys = {
            "hold-days": "cooling_days",
            "cooling-days": "cooling_days",  # alias
            "bypass-token": "bypass_token",
            "log-level": "log_level",
            "fail-open": "fail_open",
        }

        if key in server_keys:
            api_key = server_keys[key]
            try:
                api_post("/api/settings", {api_key: value})
                print(f"  {green('✓')} Server setting '{key}' updated to '{value}'")
            except SystemExit:
                print(f"  {red('✗')} Failed to update. Is the dashboard running?")
        elif key in ("url", "token"):
            config[key] = value
            save_config(config)
            print(f"  {green('✓')} CLI config '{key}' saved")
        else:
            print(f"  {red('✗')} Unknown key: {key}")
            print(f"  CLI keys: url, token")
            print(f"  Server keys: hold-days, bypass-token, log-level, fail-open")
            sys.exit(1)


# ── Main ──────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="quarry",
        description="⛏  Quarry — Supply chain security gatekeep.\n   Packages enter the Quarry. Only the proven ones leave.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""Themed commands (aliases in parentheses):
  status                    Show the hold status
  ledger   (log)            View the record of requests
  release  (allow)          Free a package from the hold
  seal     (block)          Permanently lock a package away
  unseal   (clear)          Remove seal, return to auto
  edicts   (rules)          Show standing orders
  inspect  (simulate)       Examine a package at the gate
  config                    Manage CLI configuration

Supported registries/ecosystems:
  npm, maven, pypi, nuget, go, cargo, gitlab, artifactory, docker, helm, or any custom name""",
    )
    subparsers = parser.add_subparsers(dest="command")

    # status
    subparsers.add_parser("status", help="Show the hold status")

    # ledger / log
    ledger_parser = subparsers.add_parser("ledger", help="View the record of requests")
    ledger_parser.add_argument("--limit", "-n", type=int, default=25, help="Number of entries (default: 25)")
    log_parser = subparsers.add_parser("log", help=argparse.SUPPRESS)  # alias
    log_parser.add_argument("--limit", "-n", type=int, default=25)

    # release / allow
    release_parser = subparsers.add_parser("release", help="Free a package from the hold")
    release_parser.add_argument("ecosystem", help="Registry/ecosystem (npm, maven, pypi, gitlab, etc.)")
    release_parser.add_argument("package", help="Package name")
    allow_parser = subparsers.add_parser("allow", help=argparse.SUPPRESS)  # alias
    allow_parser.add_argument("ecosystem", help="Registry/ecosystem")
    allow_parser.add_argument("package", help="Package name")

    # seal / block
    seal_parser = subparsers.add_parser("seal", help="Permanently lock a package away")
    seal_parser.add_argument("ecosystem", help="Registry/ecosystem (npm, maven, pypi, gitlab, etc.)")
    seal_parser.add_argument("package", help="Package name")
    block_parser = subparsers.add_parser("block", help=argparse.SUPPRESS)  # alias
    block_parser.add_argument("ecosystem", help="Registry/ecosystem")
    block_parser.add_argument("package", help="Package name")

    # unseal / clear
    unseal_parser = subparsers.add_parser("unseal", help="Remove seal, return to auto policy")
    unseal_parser.add_argument("ecosystem", help="Registry/ecosystem (npm, maven, pypi, gitlab, etc.)")
    unseal_parser.add_argument("package", help="Package name")
    clear_parser = subparsers.add_parser("clear", help=argparse.SUPPRESS)  # alias
    clear_parser.add_argument("ecosystem", help="Registry/ecosystem")
    clear_parser.add_argument("package", help="Package name")

    # edicts / rules
    subparsers.add_parser("edicts", help="Show standing orders (rules)")
    subparsers.add_parser("rules", help=argparse.SUPPRESS)  # alias

    # inspect / simulate
    inspect_parser = subparsers.add_parser("inspect", help="Examine a package at the gate")
    inspect_parser.add_argument("ecosystem", help="Registry/ecosystem (npm, maven, pypi, gitlab, etc.)")
    inspect_parser.add_argument("package", help="Package name")
    inspect_parser.add_argument("version", nargs="?", default=None, help="Version (optional)")
    sim_parser = subparsers.add_parser("simulate", help=argparse.SUPPRESS)  # alias
    sim_parser.add_argument("ecosystem", help="Registry/ecosystem")
    sim_parser.add_argument("package", help="Package name")
    sim_parser.add_argument("version", nargs="?", default=None)

    # config
    config_parser = subparsers.add_parser("config", help="Manage CLI configuration")
    config_sub = config_parser.add_subparsers(dest="config_action")
    config_sub.add_parser("show", help="Show current config")
    set_parser = config_sub.add_parser("set", help="Set a config value")
    set_parser.add_argument("key", help="Key (url, token, hold-days, bypass-token, log-level, fail-open)")
    set_parser.add_argument("value", help="Value to set")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(0)

    # Map aliases to themed commands
    commands = {
        "status": cmd_status,
        "ledger": cmd_ledger,
        "log": cmd_ledger,
        "release": cmd_release,
        "allow": cmd_release,
        "seal": cmd_seal,
        "block": cmd_seal,
        "unseal": cmd_unseal,
        "clear": cmd_unseal,
        "edicts": cmd_edicts,
        "rules": cmd_edicts,
        "inspect": cmd_inspect,
        "simulate": cmd_inspect,
        "config": cmd_config,
    }

    cmd_func = commands.get(args.command)
    if cmd_func:
        cmd_func(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
